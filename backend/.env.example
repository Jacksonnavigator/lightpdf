# Copy these into Render's Environment Variables section
PORT=3000
# Set this to your Render backend URL after deploying
# e.g. https://pdf-backend-xxxx.onrender.com
BASE_URL=https://YOUR-BACKEND.onrender.com
# Set this to your Render Collabora URL after deploying
# e.g. https://pdf-collabora-xxxx.onrender.com
COLLABORA_URL=https://YOUR-COLLABORA.onrender.com
DATA_DIR=/data
# IMPORTANT: must be "local" on Render — LibreOffice is inside this container
CONVERT_MODE=local
CONVERT_TIMEOUT_MS=180000
